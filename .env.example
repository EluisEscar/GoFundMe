# =============================================================================
# Variables de entorno del backend (configúralas en Vercel → Settings → Env)
# Copia este archivo a ".env" para desarrollo local con `vercel dev`.
# NUNCA subas el archivo .env real al repositorio.
# =============================================================================

# --- Supabase (Project Settings → API) ---
SUPABASE_URL=https://TU-PROYECTO.supabase.co
# OJO: usa la "service_role" key (secreta), NO la "anon". Solo vive en el servidor.
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key

# --- Panel de administración ---
# Contraseña para aprobar/rechazar donaciones desde /#admin
ADMIN_PASSWORD=pon-una-contraseña-fuerte

# --- Webhook de Yape (semi-automático con MacroDroid/Tasker) ---
# Token secreto que tu celular envía al reenviar la notificación de Yape.
# Inventa una cadena larga y aleatoria. Solo tú y tu celular la conocen.
YAPE_WEBHOOK_SECRET=cadena-larga-y-secreta-para-el-webhook
# (Opcional) Pon "false" para que las donaciones por Yape queden PENDIENTES
# y las revises en /#admin antes de que suban la barra. Por defecto se aprueban.
YAPE_WEBHOOK_AUTOAPPROVE=true
